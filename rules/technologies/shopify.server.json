{
  "$schema": "../../schemas/technologies.schema.json",
  "title": "Shopify",
  "condition": [
    {
      "type": "RESPONSE_HEADER_MATCH",
      "payload": {
        "name": "x-shopify-stage",
        "type": "START_WITH",
        "value": ""
      }
    }
  ],
  "technology_id": 2,
  "proxyHosts": ["feeds.datafeedwatch.com", "feeds.adwordsrobot.com"],
  "settings": [
    {
      "name": "Shopify excluded paths",
      "value": [
        {
          "type": "excluded_paths",
          "payload": [
            {
              "type": "CONTAIN",
              "value": "/customer_authentication/",
              "exclusion_behavior": "NOT_TRANSLATED"
            }
          ]
        }
      ]
    },
    {
      "name": "Shopify assets exclusion",
      "value": [
        {
          "type": "excluded_attributes",
          "payload": [
            {
              "selector": "script[src*=$host/cdn/shopifycloud]",
              "attributes": ["src"]
            }
          ]
        }
      ]
    },
    {
      "name": "Mollie checkout exclusion",
      "condition": [
        {
          "type": "PATH_MATCH",
          "payload": {
            "type": "MATCH_REGEX",
            "value": "/checkouts/([\\w]+)/forward"
          }
        }
      ],
      "value": [
        {
          "type": "excluded_blocks",
          "payload": [
            {
              "value": "#payment-form"
            }
          ]
        }
      ]
    },
    {
      "name": "Shopify Checkout page",
      "condition": [
        {
          "type": "PATH_MATCH",
          "payload": {
            "type": "MATCH_REGEX",
            "value": "/(\\d+)/checkouts/(\\w{32})"
          }
        }
      ],
      "value": [
        {
          "type": "whitelist",
          "payload": [
            {
              "value": "table.product-table .product__description__name"
            },
            {
              "value": "aside.sidebar #icons_text_section section div.description"
            }
          ]
        }
      ]
    },
    {
      "name": "Prevent JS script injection on Sandbox tracking pages",
      "condition": [
        {
          "type": "PATH_MATCH",
          "payload": {
            "type": "CONTAIN",
            "value": "/sandbox/modern"
          }
        }
      ],
      "value": [
        {
          "type": "auto_inject_script",
          "payload": false
        }
      ]
    }
  ]
}
