{
  "$schema": "../../schemas/proxy.schema.json",
  "title": "Wix proxy rules",
  "proxy": [
    {
      "condition": [
        {
          "type": "TECHNOLOGY_ID",
          "payload": 6
        },
        {
          "type": "HOST_MATCH",
          "payload": {
            "type": "MATCH_REGEX",
            "value": "(?:\\.parastorage\\.com|\\.wixapps\\.net|\\.wixstatic\\.com|^ecom\\.wix\\.com$)"
          }
        }
      ],
      "value": [
        {
          "action": "ALLOW_HOST"
        }
      ]
    }
  ]
}
